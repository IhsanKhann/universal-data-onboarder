# ═══════════════════════════════════════════════════════════════════════════════
# Universal Data Onboarding Engine — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values. Every variable has a
# documented default where one exists; variables marked (required) will
# cause the engine to fail at startup if unset.
#
# ── Organisation ─────────────────────────────────────────────────────────────
# Variables are grouped by concern: guardrails → adapters → databases →
# queue → storage → GCP deployment. Set only what your deployment needs.

# ═══════════════════════════════════════════════════════════════════════════════
# 1. GUARDRAILS — Row/byte ceilings that protect the engine from oversized files
# ═══════════════════════════════════════════════════════════════════════════════

# Maximum number of rows a shared-tier tenant may import in one file.
# Breach of this ceiling → guardrail_rejected with an upgrade CTA.
ONBOARDER_SHARED_MAX_ROWS=20000

# Maximum number of rows a dedicated-tier tenant may import in one file.
# Dedicated tenants typically have their own database and higher limits.
ONBOARDER_DEDICATED_MAX_ROWS=50000

# Maximum file size (bytes) for shared-tier tenants.
# Default = 20 MB.
ONBOARDER_SHARED_MAX_BYTES=20971520

# Maximum file size (bytes) for dedicated-tier tenants.
# Default = 512 MB.
ONBOARDER_DEDICATED_MAX_BYTES=536870912

# Threshold below which commits run synchronously (inline in the HTTP
# response). Imports above this threshold are enqueued to the async
# BullMQ worker for chunked processing. Raise this if your workers
# are fast and your HTTP timeout is generous.
ONBOARDER_SYNC_COMMIT_THRESHOLD=200

# ═══════════════════════════════════════════════════════════════════════════════
# 2. ADAPTER SELECTION — Swap adapters without changing code.
#    Each *_ADAPTER env var picks the implementation to use.
# ═══════════════════════════════════════════════════════════════════════════════

# Which JobStore implementation to use.
#   "mongoose"   — Mongoose-backed job store (default, requires MONGO_URI)
#   "in-memory"  — In-memory job store (for testing only, data lost on restart)
JOB_STORE_ADAPTER=mongoose

# Which queue implementation to use.
#   "bullmq"     — BullMQ-backed queue (default, requires REDIS_URL)
#   "in-memory"  — In-memory queue (resolves synchronously, no Redis needed)
QUEUE_ADAPTER=in-memory

# Which storage implementation to use for file uploads.
#   "local-fs"  — Local filesystem storage (default, requires LOCAL_STORAGE_DIR)
#   "gcs"       — Google Cloud Storage (requires GCS_BUCKET, GCP_PROJECT_ID)
#   "s3"        — AWS S3 (requires AWS_* env vars)
STORAGE_ADAPTER=local-fs

# Which connection resolver implementation to use for tenant DB resolution.
#   "mongoose-tenant" — Multi-tenant connection resolver (reads control plane)
#   "single"          — Single connection resolver (always returns MONGO_URI)
CONNECTION_ADAPTER=single

# ═══════════════════════════════════════════════════════════════════════════════
# 3. DATABASE CONNECTIONS
# ═══════════════════════════════════════════════════════════════════════════════

# Main MongoDB connection string. Required if using "mongoose" adapters.
# For multi-tenant setups, this may be the control-plane connection string.
MONGO_URI=mongodb://localhost:27017/onboarder

# ═══════════════════════════════════════════════════════════════════════════════
# 4. QUEUE (BullMQ)
# ═══════════════════════════════════════════════════════════════════════════════

# Redis connection string for BullMQ. Required if QUEUE_ADAPTER=bullmq.
REDIS_URL=redis://localhost:6379

# Name of the BullMQ queue for async migration commits.
QUEUE_NAME=onboarder-migration-commit

# ═══════════════════════════════════════════════════════════════════════════════
# 5. STORAGE
# ═══════════════════════════════════════════════════════════════════════════════

# Local filesystem storage directory. Required if STORAGE_ADAPTER=local-fs.
LOCAL_STORAGE_DIR=./tmp/uploads

# Google Cloud Storage bucket name. Required if STORAGE_ADAPTER=gcs.
GCS_BUCKET=

# ═══════════════════════════════════════════════════════════════════════════════
# 6. CLOUD RUN JOB (worker/cloudRunEntrypoint.js)
# ═══════════════════════════════════════════════════════════════════════════════

# ImportJob _id on the tenant's own database. Required for single-job mode.
IMPORT_JOB_ID=

# Tenant _id. Required.
TENANT_ID=

# MigrationSession _id. If set, runs all jobs in the session in dependency order.
# Mutually exclusive with IMPORT_JOB_ID.
SESSION_ID=

# GCS staging bucket and object path. Required for single-job mode with GCS.
GCS_BUCKET_NAME=
GCS_OBJECT_PATH=

# ═══════════════════════════════════════════════════════════════════════════════
# 7. GCP DEPLOYMENT (infra/gcp-cloud-run/)
# ═══════════════════════════════════════════════════════════════════════════════

# Google Cloud project ID and region for Cloud Run Job deployment.
GCP_PROJECT_ID=
GCP_REGION=us-central1

# Artifact Registry repository for storing worker images.
GCP_ARTIFACT_REGISTRY=

# ═══════════════════════════════════════════════════════════════════════════════
# 8. LOGGING
# ═══════════════════════════════════════════════════════════════════════════════

# Log level. One of: debug, info, warn, error.
LOG_LEVEL=info
